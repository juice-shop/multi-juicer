  "scripts": {
    "start": "vite -c ui/vite.config.ts",
    "build": "vite build -c ui/vite.config.ts",
    "serve": "vite preview -c ui/vite.config.ts",
    "test": "vitest -c ui/vitest.config.ts --watch=false",
